{
  "info": {
    "name": "Farmers Market API",
    "description": "POS Operator Portal - Farmers Market Platform\nBase URL: http://127.0.0.1:8000/api\n\nDemo Accounts:\n- Admin:      admin@farmarket.ci      / password\n- Supervisor: supervisor@farmarket.ci / password\n- Operator:   operator@farmarket.ci   / password\n\nRoles:\n- admin: manages supervisors\n- supervisor: manages operators, categories, products\n- operator: manages farmers, places orders, records repayments",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000/api", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "admin_token", "value": "", "type": "string" },
    { "key": "supervisor_token", "value": "", "type": "string" },
    { "key": "operator_token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('admin_token', res.data.token);",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "  console.log('Admin token saved:', res.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@farmarket.ci\",\n  \"password\": \"password\"\n}"
            },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Login successful\",\n  \"data\": {\n    \"token\": \"1|abc123xyz...\",\n    \"user\": {\n      \"id\": 1,\n      \"name\": \"Admin Principal\",\n      \"email\": \"admin@farmarket.ci\",\n      \"role\": \"admin\"\n    }\n  }\n}"
            },
            {
              "name": "Error - Invalid Credentials",
              "status": "Unprocessable Content",
              "code": 422,
              "body": "{\n  \"success\": false,\n  \"message\": \"Validation failed\",\n  \"errors\": {\n    \"email\": [\"These credentials do not match our records.\"]\n  }\n}"
            }
          ]
        },
